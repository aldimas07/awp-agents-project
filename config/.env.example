# .env.example for AWP Agents Project
# Copy this file to .env in the same directory and fill in your actual values.
# This file should NOT be committed to version control with your secrets.

# --- Global API Keys and Endpoints ---
# Your OpenAI-compatible API Key
OPENAI_API_KEY="your_openai_api_key_here"
# Base URL for your OpenAI-compatible LLM service
OPENAI_BASE_URL="https://api.bluesminds.com/v1"

# --- AWP Platform Settings ---
# Base URL for the AWP prediction/mining platform
PLATFORM_BASE_URL="https://api.minework.net"

# --- Default LLM Models ---
# Primary LLM model used for predictions
PREDICT_MODEL="gemini/gemini-2.5-flash"
# Fallback LLM model (used if primary fails). Can be the same as PREDICT_MODEL.
OPENAI_MODEL="gemini/gemini-2.5-flash"

# --- General Agent Settings ---
# Maximum parallel workers (if applicable for miner)
WORKER_MAX_PARALLEL=3
# How often the dataset refreshes (in seconds)
DATASET_REFRESH_SECONDS=15

# --- Watchdog Settings ---
# Interval for watchdog health checks (in seconds)
WATCHDOG_CHECK_INTERVAL=60
